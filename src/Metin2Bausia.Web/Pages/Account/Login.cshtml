@page "/account/login"
@model Metin2Bausia.Web.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Přihlášení — Metin2Bausia Admin</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: #0f0f1e;
            color: #e0e0f0;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .login-box {
            background: #1a1a2e;
            border: 1px solid #2a2a4a;
            border-radius: 8px;
            padding: 40px;
            width: 360px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        h1 {
            color: #dcb43c;
            font-size: 1.6rem;
            margin-bottom: 6px;
        }
        .subtitle { color: #888; font-size: 0.85rem; margin-bottom: 28px; }
        label { display: block; font-size: 0.85rem; color: #aaa; margin-bottom: 5px; margin-top: 16px; }
        input {
            width: 100%;
            padding: 10px 12px;
            background: #0f0f1e;
            border: 1px solid #333;
            border-radius: 4px;
            color: #e0e0f0;
            font-size: 0.95rem;
            outline: none;
            transition: border-color .2s;
        }
        input:focus { border-color: #dcb43c; }
        .btn {
            display: block;
            width: 100%;
            margin-top: 24px;
            padding: 11px;
            background: #dcb43c;
            color: #0f0f1e;
            font-size: 1rem;
            font-weight: 700;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            transition: background .2s;
        }
        .btn:hover { background: #f0c84a; }
        .error {
            background: rgba(180,40,40,.2);
            border: 1px solid #b42828;
            border-radius: 4px;
            padding: 10px 14px;
            color: #f08080;
            font-size: 0.85rem;
            margin-top: 16px;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <h1>Metin2 Bausia</h1>
        <p class="subtitle">Admin správa obsahu</p>

        <form method="post">
            @Html.AntiForgeryToken()

            <label for="email">E-mail</label>
            <input type="email" id="email" name="email"
                   value="@Model.Email" autocomplete="username" required />

            <label for="password">Heslo</label>
            <input type="password" id="password" name="password"
                   autocomplete="current-password" required />

            <button type="submit" class="btn">Přihlásit se</button>

            @if (Model.Error != null)
            {
                <div class="error">@Model.Error</div>
            }
        </form>
    </div>
</body>
</html>
