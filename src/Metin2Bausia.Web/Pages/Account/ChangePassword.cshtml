@page "/account/change-password"
@model Metin2Bausia.Web.Pages.Account.ChangePasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Změna hesla — Metin2Bausia Admin</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: #0f0f1e;
            color: #e0e0f0;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .login-box {
            background: #1a1a2e;
            border: 1px solid #2a2a4a;
            border-radius: 8px;
            padding: 40px;
            width: 380px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        h1 { color: #dcb43c; font-size: 1.5rem; margin-bottom: 6px; }
        .subtitle { color: #888; font-size: 0.85rem; margin-bottom: 20px; }
        .warning {
            background: rgba(180,120,0,.15);
            border: 1px solid #dcb43c;
            border-radius: 4px;
            padding: 10px 14px;
            color: #dcb43c;
            font-size: 0.85rem;
            margin-bottom: 20px;
        }
        label { display: block; font-size: 0.85rem; color: #aaa; margin-bottom: 5px; margin-top: 16px; }
        input {
            width: 100%;
            padding: 10px 12px;
            background: #0f0f1e;
            border: 1px solid #333;
            border-radius: 4px;
            color: #e0e0f0;
            font-size: 0.95rem;
            outline: none;
            transition: border-color .2s;
        }
        input:focus { border-color: #dcb43c; }
        .btn {
            display: block;
            width: 100%;
            margin-top: 24px;
            padding: 11px;
            background: #dcb43c;
            color: #0f0f1e;
            font-size: 1rem;
            font-weight: 700;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            transition: background .2s;
        }
        .btn:hover { background: #f0c84a; }
        .error {
            background: rgba(180,40,40,.2);
            border: 1px solid #b42828;
            border-radius: 4px;
            padding: 10px 14px;
            color: #f08080;
            font-size: 0.85rem;
            margin-top: 16px;
        }
        .success {
            background: rgba(30,126,52,.2);
            border: 1px solid #1e7e34;
            border-radius: 4px;
            padding: 10px 14px;
            color: #5cb85c;
            font-size: 0.85rem;
            margin-top: 16px;
        }
        small { display: block; color: #666; font-size: 0.78rem; margin-top: 4px; }
    </style>
</head>
<body>
    <div class="login-box">
        <h1>Metin2 Bausia</h1>
        <p class="subtitle">Nastavení administrátora</p>

        @if (Model.IsMandatory)
        {
            <div class="warning">
                ⚠ Povinná změna hesla. Nastav si nové heslo před pokračováním.
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            @if (!Model.IsMandatory)
            {
                <label for="currentPassword">Aktuální heslo</label>
                <input type="password" id="currentPassword" name="currentPassword"
                       autocomplete="current-password" />
            }

            <label for="newPassword">Nové heslo</label>
            <input type="password" id="newPassword" name="newPassword"
                   autocomplete="new-password" required minlength="6" />
            <small>Minimálně 6 znaků</small>

            <label for="confirmPassword">Nové heslo znovu</label>
            <input type="password" id="confirmPassword" name="confirmPassword"
                   autocomplete="new-password" required />

            <button type="submit" class="btn">Změnit heslo</button>

            @if (Model.Error != null)
            {
                <div class="error">@Model.Error</div>
            }
            @if (Model.Success != null)
            {
                <div class="success">@Model.Success</div>
            }
        </form>
    </div>
</body>
</html>
