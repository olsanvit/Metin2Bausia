@page "/manage/mobs"
@attribute [Authorize]
@inject IDbService Db

<PageTitle>Správa mobů / NPC / Metinů — Metin2Bausia</PageTitle>

<h2>Správa mobů, NPC a Metinů</h2>
<p class="text-muted mb-3">Zapínej/vypínej obsah ve hře. Nové záznamy jsou ve výchozím stavu <strong>vypnuté</strong>.</p>

<div class="toolbar mb-3 d-flex gap-2 align-items-center flex-wrap">
    <input class="form-control form-control-sm" style="max-width:220px"
           placeholder="Hledat název / vnum..."
           @bind="_search" @bind:event="oninput" />

    <div class="btn-group btn-group-sm" role="group">
        <button class="btn @(_tab=="all"?"btn-primary":"btn-outline-secondary")"
                @onclick='() => _tab="all"'>Vše</button>
        <button class="btn @(_tab=="monster"?"btn-danger":"btn-outline-secondary")"
                @onclick='() => _tab="monster"'>Monstři</button>
        <button class="btn @(_tab=="npc"?"btn-info":"btn-outline-secondary")"
                @onclick='() => _tab="npc"'>NPC</button>
        <button class="btn @(_tab=="metin"?"btn-warning":"btn-outline-secondary")"
                @onclick='() => _tab="metin"'>Metiny</button>
        <button class="btn @(_tab=="boss"?"btn-dark":"btn-outline-secondary")"
                @onclick='() => _tab="boss"'>Bossové</button>
    </div>

    <select class="form-select form-select-sm" style="max-width:140px" @bind="_filterEnabled">
        <option value="">Vše</option>
        <option value="true">Zapnuté</option>
        <option value="false">Vypnuté</option>
    </select>

    <span class="text-muted small ms-auto">Zobrazeno: @Filtered.Count() / @_mobs.Count</span>
</div>

@if (_loading)
{
    <p>Načítám...</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width:56px">Zapnuto</th>
                    <th style="width:70px">Vnum</th>
                    <th>Název</th>
                    <th style="width:60px">Level</th>
                    <th style="width:90px">Typ</th>
                    <th style="width:90px">Rank</th>
                    <th style="width:100px">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mob in Filtered)
                {
                    <tr class="@(mob.IsEnabled ? "" : "opacity-60")">
                        <td class="text-center">
                            <div class="form-check form-switch d-flex justify-content-center">
                                <input class="form-check-input" type="checkbox"
                                       checked="@mob.IsEnabled"
                                       @onchange="e => ToggleAsync(mob, (bool)e.Value!)" />
                            </div>
                        </td>
                        <td><code class="small">@mob.Vnum</code></td>
                        <td>
                            <strong>@mob.Name</strong>
                            @if (mob.LocaleName != null)
                            { <small class="text-muted"> (@mob.LocaleName)</small> }
                        </td>
                        <td class="text-muted small">@mob.Level</td>
                        <td><span class="badge @MobTypeBadge(mob.MobType)">@MobTypeName(mob.MobType)</span></td>
                        <td><span class="badge @RankBadge(mob.Rank)">@RankName(mob.Rank)</span></td>
                        <td><span class="badge @StatusClass(mob.ContentStatus)">@mob.ContentStatus</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_message != null)
{
    <div class="toast-msg @(_isError ? "toast-err" : "toast-ok")">@_message</div>
}

@code {
    private bool _loading = true;
    private List<ManageMob> _mobs = new();
    private string _search = "";
    private string _tab = "all";
    private string _filterEnabled = "";
    private string? _message;
    private bool _isError;

    private IEnumerable<ManageMob> Filtered => _mobs.Where(m =>
        (string.IsNullOrEmpty(_search) ||
            (m.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true) ||
            (m.Vnum?.ToString() == _search)) &&
        (string.IsNullOrEmpty(_filterEnabled) || m.IsEnabled.ToString().ToLower() == _filterEnabled) &&
        _tab switch
        {
            "monster" => m.MobType == 0,
            "npc"     => m.MobType == 1,
            // Metiny: Vnum 8001–8999 nebo MobType=2 (stone)
            "metin"   => m.MobType == 2 || (m.Vnum >= 8001 && m.Vnum <= 8999),
            "boss"    => m.Rank >= 4,
            _         => true
        });

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _mobs = (await Db.QueryAsync<ManageMob>(
                @"SELECT ""Guid"", ""Vnum"", ""Name"", ""LocaleName"", ""Level"",
                         ""MobType"", ""Rank"", ""ContentStatus"", ""IsEnabled"", ""SourceName""
                  FROM ""Mobs""
                  WHERE ""IsDeleted"" = FALSE
                  ORDER BY ""IsEnabled"" DESC, ""Vnum"" ASC NULLS LAST
                  LIMIT 5000")).ToList();
        }
        catch (Exception ex) { _message = ex.Message; _isError = true; }
        finally { _loading = false; }
    }

    private async Task ToggleAsync(ManageMob mob, bool newValue)
    {
        var old = mob.IsEnabled;
        mob.IsEnabled = newValue;
        try
        {
            await Db.ExecuteAsync(
                @"UPDATE ""Mobs"" SET ""IsEnabled"" = @v, ""UpdatedAt"" = NOW() WHERE ""Guid"" = @g",
                new { v = newValue, g = mob.Guid });
            _message = newValue ? $"✓ {mob.Name} zapnuto" : $"○ {mob.Name} vypnuto";
            _isError = false;
        }
        catch (Exception ex)
        {
            mob.IsEnabled = old;
            _message = $"Chyba: {ex.Message}";
            _isError = true;
        }
    }

    private static string MobTypeName(int? t) => t switch
    {
        0 => "Příšera", 1 => "NPC", 2 => "Metin", 3 => "Příšera2", 4 => "Truhla", _ => "?"
    };
    private static string MobTypeBadge(int? t) => t switch
    {
        1 => "bg-info text-dark", 2 => "bg-warning text-dark", 4 => "bg-secondary", _ => "bg-danger"
    };
    private static string RankName(int? r) => r switch
    {
        0 => "Pěšák", 1 => "S-Pěšák", 2 => "Rytíř", 3 => "S-Rytíř", 4 => "Boss", 5 => "Král", _ => "?"
    };
    private static string RankBadge(int? r) => r switch
    {
        4 => "bg-danger", 5 => "bg-dark", _ => "bg-secondary"
    };
    private static string StatusClass(string? s) => s switch
    {
        "approved" => "bg-success", "pending" => "bg-warning text-dark", _ => "bg-secondary"
    };
}
