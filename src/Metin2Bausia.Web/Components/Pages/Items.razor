@page "/items"
@inject IDbService Db

<PageTitle>Itemy ke schválení — Metin2Bausia</PageTitle>

<h2>Itemy čekající na schválení</h2>

@if (_loading)
{
    <p>Načítám...</p>
}
else if (!_items.Any())
{
    <div class="alert alert-info">Žádné itemy ke schválení.</div>
}
else
{
    <p class="text-muted">Celkem: @_items.Count itemů</p>
    <table class="table table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Vnum</th>
                <th>Name</th>
                <th>Typ</th>
                <th>Zdroj</th>
                <th>Confidence</th>
                <th>Vytvořen</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr class="@(_processing == item.Guid ? "table-secondary" : "")">
                    <td><code>@item.Vnum</code></td>
                    <td><strong>@item.Name</strong>@if (item.LocaleName != null) { <small class="text-muted"> (@item.LocaleName)</small> }</td>
                    <td>@item.ItemType</td>
                    <td>
                        @if (item.SourceUrl != null)
                        {
                            <a href="@item.SourceUrl" target="_blank" class="text-truncate d-inline-block" style="max-width:120px">@item.SourceName</a>
                        }
                        else { <span>@item.SourceName</span> }
                    </td>
                    <td>
                        <span class="badge @(item.ConfidenceScore >= 80 ? "bg-success" : item.ConfidenceScore >= 50 ? "bg-warning text-dark" : "bg-danger")">
                            @item.ConfidenceScore
                        </span>
                    </td>
                    <td>@item.CreatedAt.ToString("dd.MM.yy")</td>
                    <td>
                        <button class="btn btn-sm btn-success me-1" disabled="@(_processing != null)"
                                @onclick="() => ApproveAsync(item)">✓</button>
                        <button class="btn btn-sm btn-danger" disabled="@(_processing != null)"
                                @onclick="() => RejectAsync(item)">✗</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_message != null)
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") mt-2">@_message</div>
}

@code {
    private bool _loading = true;
    private List<PendingItem> _items = new();
    private Guid? _processing;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _items = (await Db.QueryAsync<PendingItem>(
                "SELECT \"Guid\", \"Vnum\", \"Name\", \"LocaleName\", \"ItemType\", \"ContentStatus\", \"SourceName\", \"SourceUrl\", \"CreatedAt\", \"ConfidenceScore\" " +
                "FROM \"Items\" WHERE \"ContentStatus\" = 'pending' AND \"IsDeleted\" = false " +
                "ORDER BY \"ConfidenceScore\" DESC NULLS LAST, \"CreatedAt\" DESC LIMIT 200")).ToList();
        }
        catch (Exception ex) { _message = $"Chyba DB: {ex.Message}"; _isError = true; }
        finally { _loading = false; }
    }

    private async Task ApproveAsync(PendingItem item)
    {
        _processing = item.Guid;
        try
        {
            await Db.ExecuteAsync(
                "UPDATE \"Items\" SET \"ContentStatus\" = 'approved', \"ApprovalAt\" = NOW(), \"ApprovalBy\" = 'admin', \"UpdatedAt\" = NOW() WHERE \"Guid\" = @Guid",
                new { item.Guid });
            await Db.ExecuteAsync(
                "INSERT INTO \"ApprovalLog\" (\"Guid\", \"EntityTable\", \"EntityGuid\", \"Action\", \"Operator\", \"CreatedAt\") VALUES (gen_random_uuid(), 'Items', @Guid, 'approved', 'admin', NOW())",
                new { item.Guid });
            _message = $"✓ Item '{item.Name}' (Vnum {item.Vnum}) schválen.";
            _isError = false;
            _items.Remove(item);
        }
        catch (Exception ex) { _message = $"Chyba: {ex.Message}"; _isError = true; }
        finally { _processing = null; }
    }

    private async Task RejectAsync(PendingItem item)
    {
        _processing = item.Guid;
        try
        {
            await Db.ExecuteAsync(
                "UPDATE \"Items\" SET \"ContentStatus\" = 'rejected', \"RejectedAt\" = NOW(), \"RejectedReason\" = 'manual_reject', \"UpdatedAt\" = NOW() WHERE \"Guid\" = @Guid",
                new { item.Guid });
            _message = $"✗ Item '{item.Name}' zamítnut.";
            _isError = false;
            _items.Remove(item);
        }
        catch (Exception ex) { _message = $"Chyba: {ex.Message}"; _isError = true; }
        finally { _processing = null; }
    }
}
