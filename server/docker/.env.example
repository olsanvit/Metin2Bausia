# ============================================================
# Metin2Bausia — herní server — proměnné prostředí
# Zkopírovat jako .env a vyplnit skutečné hodnoty
# ============================================================

# MySQL root heslo (pro mt2-mysql kontejner)
MYSQL_ROOT_PASSWORD=bausia_root_secret

# Veřejná IP herního serveru (hráči se připojují na tuto adresu)
# Nastav na skutečnou veřejnou IP QNAP nebo VPS
MT2_PUBLIC_IP=0.0.0.0

# Port herního serveru (výchozí TMP4: 13000)
MT2_GAME_PORT=13000

# Zkratka serveru (pro logy)
MT2_SERVER_NAME=Metin2Bausia
